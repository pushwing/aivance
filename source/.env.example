# ─── AIvance 도입 문의 폼 — Zoho SMTP 설정 ───────────────────────────────
# 이 파일을 복사해 .env 를 만들고 값을 채우세요:  cp .env.example .env
# .env 는 절대 커밋하지 않습니다 (.gitignore 에 등록됨).

# Zoho SMTP 서버 (한국/글로벌 계정: smtp.zoho.com / EU: smtp.zoho.eu)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
# SMTP_SECURE 는 ssl(465) 또는 tls(587)
SMTP_SECURE=ssl

# 인증 계정 — 실제 로그인 가능한 Zoho 메일함
# Zoho 는 일반 비밀번호 대신 "앱 비밀번호(App Password)" 사용을 권장합니다.
# Zoho Mail → 설정 → 보안 → 앱 비밀번호 에서 발급.
SMTP_USER=advisor@aivance.kr
SMTP_PASS=여기에_Zoho_앱_비밀번호

# 메일 발신/수신
MAIL_FROM=advisor@aivance.kr
MAIL_FROM_NAME="AIvance 홈페이지 문의"
MAIL_TO=advisor@aivance.kr

# CORS 허용 오리진 (폼이 올라간 사이트 주소). 로컬 개발은 * 로 두어도 됩니다.
ALLOWED_ORIGIN=*
