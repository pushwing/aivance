# ─── AIvance 도입 문의 폼 — Gmail SMTP 설정 ──────────────────────────────
# 이 파일을 복사해 .env 를 만들고 값을 채우세요:  cp .env.example .env
# .env 는 절대 커밋하지 않습니다 (.gitignore 에 등록됨).

# Gmail SMTP 서버
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
# SMTP_SECURE 는 ssl(465) 또는 tls(587)
SMTP_SECURE=ssl

# 인증 계정 — 실제 로그인 가능한 Gmail 계정
# Gmail 은 일반 비밀번호로 SMTP 인증이 불가하며 "앱 비밀번호(App Password)"가 필요합니다.
# Google 계정 → 보안 → 2단계 인증 활성화 → 앱 비밀번호 에서 16자리 발급 (공백 없이 입력).
SMTP_USER=blumine@gmail.com
SMTP_PASS=여기에_Gmail_앱_비밀번호

# 메일 발신/수신
# Gmail 은 발신 주소(From)를 인증 계정 또는 "다른 주소에서 메일 보내기"로 검증된 별칭만 허용합니다.
MAIL_FROM=blumine@gmail.com
MAIL_FROM_NAME="AIvance 홈페이지 문의"
MAIL_TO=advisor@aivance.kr

# CORS 허용 오리진 (폼이 올라간 사이트 주소). 로컬 개발은 * 로 두어도 됩니다.
ALLOWED_ORIGIN=*
